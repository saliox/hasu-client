{
  "name": "cap-hub",
  "version": "0.12.11",
  "description": "Cap Hub — capes Minecraft personnalisées via le canal OptiFine (HTTP, sans certificat ni CA), gestion des capes officielles Mojang (compte Microsoft/token), registre partagé entre joueurs 100 % GitHub, aperçu animé, détection automatique du lancement de Minecraft, auto-update",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/make-icon.mjs",
    "test": "node scripts/test.mjs",
    "dist": "electron-builder --win",
    "pack": "electron-builder --win --dir",
    "publish:update": "node scripts/publish-update.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.saliox.caphub",
    "productName": "Cap Hub",
    "electronLanguages": ["fr", "en-US"],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "src/**/*",
      "renderer/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "Cap Hub Setup ${version}.${ext}",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "Cap Hub ${version} portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "Cap Hub",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false
    }
  }
}
